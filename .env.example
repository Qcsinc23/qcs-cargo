# Copy to .env and set for local or production. .env is gitignored; never commit secrets.

# SQLite DB path (or Postgres URL). WAL mode recommended for SQLite.
DATABASE_URL=file:qcs.db?_journal_mode=WAL
# HTTP port for the server.
PORT=8080
# Secret for JWT signing; must be at least 32 characters.
JWT_SECRET=your-256-bit-secret-at-least-32-chars
# Resend API key for transactional email (magic link, reset, notifications). Get key: https://resend.com/api-keys
# RESEND_API_KEY=
# Stripe secret key (sk_live_... or sk_test_...). Server-side only; never expose.
STRIPE_SECRET_KEY=
# Stripe publishable key (pk_live_... or pk_test_...). Used by browser for Stripe.js.
# STRIPE_PUBLISHABLE_KEY=
# Stripe webhook signing secret (whsec_...). From Dashboard → Developers → Webhooks → Signing secret.
STRIPE_WEBHOOK_SECRET=
# Base URL for magic links, cookies, redirects. Production: https://qcs-cargo.com
APP_URL=http://localhost:8080
# Sender address for transactional email. Omit to use Resend sandbox (onboarding@resend.dev).
# FROM_EMAIL=noreply@yourdomain.com
# Local directory for uploads (avatars, etc.). Served at /uploads. Default: ./uploads
# UPLOAD_DIR=./uploads
# Comma-separated CORS origins (e.g. https://app.qcs-cargo.com). Empty = allow all (dev only).
# ALLOWED_ORIGINS=
