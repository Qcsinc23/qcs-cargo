# Copy to .env and set for local or production.
# .env is gitignored; never commit secrets.

DATABASE_URL=file:qcs.db?_journal_mode=WAL
PORT=8080
JWT_SECRET=your-256-bit-secret-at-least-32-chars
# Base URL for magic links, cookies, etc. Production: https://qcs-cargo.com
APP_URL=http://localhost:8080
# APP_URL=https://qcs-cargo.com

# Optional: email (magic links, contact form)
# RESEND_API_KEY=
# FROM_EMAIL=noreply@yourdomain.com

# Stripe (required for ship request payment)
# Secret key (sk_live_... or sk_test_...): server-side only, never expose.
STRIPE_SECRET_KEY=
# Publishable key (pk_live_... or pk_test_...): used by browser for Stripe.js.
STRIPE_PUBLISHABLE_KEY=
# Webhook signing secret (whsec_...): from Dashboard → Developers → Webhooks → [endpoint] → Signing secret.
# Required for POST /api/webhooks/stripe (payment_intent.succeeded → reconcile ship request).
STRIPE_WEBHOOK_SECRET=

# If you ever expose a secret key (e.g. in chat or logs), rotate it immediately
# in Stripe Dashboard: Developers → API keys → Roll key.
